// Rule 11.2: Conversions shall not be performed between a pointer to an incomplete
// type and any other type.

struct Incomplete; // Forward declaration/Incomplete type

struct Complete {
    val: i32,
}

fn main() -> i32 {
    let c: Complete* = (Complete*)0;
    let i: Incomplete* = (Incomplete*)c; // EXPECT: MISRA Rule 11.2
    return 0;
}
