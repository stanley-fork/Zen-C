// MISRA Rule 5.1 Verification: External identifiers shall be distinct
// EXPECT: MISRA Rule 5.1
// EXPECT: MISRA Rule 5.1
// EXPECT: MISRA Rule 5.1
// EXPECT: MISRA Rule 5.1

// ============================================================================
// VIOLATION SECTION
// Identifiers that collide in the first 31 characters:
// ============================================================================

// 1. Global functions collision
fn long_global_function_name_that_should_collide_A() {}
fn long_global_function_name_that_should_collide_B() {}

struct S { x: i32 }

impl S {
    // 2. Standard methods collision
    fn long_method_name_that_should_collide_A(self) { self.x = 1; }
    fn long_method_name_that_should_collide_B(self) { self.x = 2; }

    // 3. Async methods collision
    async fn long_async_method_name_that_should_collide_A(self) { self.x = 3; }
    async fn long_async_method_name_that_should_collide_B(self) { self.x = 4; }
}

trait Action {
    fn execute(self);
}

// 4. Trait implementations collision
trait CollisionTrait {
    fn long_trait_method_name_that_should_collide_A(self);
}

impl CollisionTrait for S {
    fn long_trait_method_name_that_should_collide_A(self) { self.x = 6; }
    fn long_trait_method_name_that_should_collide_B(self) { self.x = 7; }
}

// ============================================================================
// COMPLIANCE SECTION
// Using @link_name to ensure distinctness despite long Zen C names:
// ============================================================================

@link_name("distinct_global_1")
fn very_long_function_name_that_is_now_compliant_A() {}

@link_name("distinct_global_2")
fn very_long_function_name_that_is_now_compliant_B() {}

impl S {
    @link_name("distinct_async_impl")
    async fn very_long_async_method_name_that_is_now_compliant(self) {
        self.x = 5;
    }
}

impl Action for S {
    @link_name("distinct_trait_impl")
    fn execute(self) { self.x = 6; }
}

fn main() {
    let s = S{x: 0};

    // Compliance cases are reachable and link correctly
    very_long_function_name_that_is_now_compliant_A();
    s.very_long_async_method_name_that_is_now_compliant();
    s.execute();
}
