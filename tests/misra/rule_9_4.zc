// Rule 9.4: A variable shall not be initialized more than once.
// In Zen C, this applies to struct fields in a struct initializer.

struct Point {
    x: i32,
    y: i32,
}

fn main() -> i32 {
    let p = Point {
        x: 1,
        y: 2,
        x: 3, // EXPECT: MISRA Rule 9.4
    };
    return 0;
}
